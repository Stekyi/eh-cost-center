# Frontend (Vite) env for the Cloudflare Pages + Neon stack.
# Copy to .env.local for dev; set the same vars in the Cloudflare Pages dashboard.

# Base URL of the deployed Cloudflare Worker API (no trailing slash).
VITE_API_BASE="https://eh-cost-center-api.samuel-asamoah-tekyi.workers.dev"

# Backend selector for the compat layer. 'neon' uses the Worker (new stack).
# During transition, unmigrated screens still import firebaseClient directly.
VITE_DATA_BACKEND="neon"

# ── Legacy Firebase vars (kept until Firebase is fully decommissioned) ──
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
