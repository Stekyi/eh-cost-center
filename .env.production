# Production build config for Cloudflare Pages (Vite reads this at build time).
# These are NOT secrets — the Worker URL is public and "neon" is just a mode flag.
# Committed so any build (local `npm run build` or Pages git build) points at the Worker.
VITE_API_BASE=https://eh-cost-center-api.samuel-asamoah-tekyi.workers.dev
VITE_DATA_BACKEND=neon
